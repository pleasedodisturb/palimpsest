# =============================================================================
# Palimpsest Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files with real credentials.

# ---------------------------------------------------------------------------
# Google APIs
# ---------------------------------------------------------------------------
# OAuth credentials file (download from Google Cloud Console)
# PAC_GOOGLE_CREDENTIALS=path/to/credentials.json

# Default Google Drive folder for uploads
# PAC_DOCS_FOLDER=your_drive_folder_id

# Write guard — set to "1" to allow Google Docs/Sheets writes
PAC_WRITE_GUARD=0

# ---------------------------------------------------------------------------
# Atlassian (Confluence + Jira)
# ---------------------------------------------------------------------------
# Your Atlassian domain (e.g., mycompany.atlassian.net)
ATLASSIAN_DOMAIN=

# Atlassian account email
ATLASSIAN_EMAIL=

# Atlassian API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
ATLASSIAN_API_TOKEN=

# ---------------------------------------------------------------------------
# Confluence Page IDs
# ---------------------------------------------------------------------------
# Path to pages.json config file (alternative to individual env vars)
# PAGES_CONFIG=path/to/pages.json

# Updates page ID (daily news)
PAC_CONFLUENCE_UPDATES_PAGE_ID=

# Weekly summary page ID
PAC_CONFLUENCE_WEEKLY_PAGE_ID=

# ---------------------------------------------------------------------------
# Jira
# ---------------------------------------------------------------------------
# Jira project key for ticket drafting
JIRA_PROJECT_KEY=

# ---------------------------------------------------------------------------
# Python / Runtime
# ---------------------------------------------------------------------------
# Override Python binary (default: auto-discover venv or sys.executable)
# PAC_PYTHON=path/to/python

# Project root directory
# PAC_PROJECT_ROOT=path/to/project

# ---------------------------------------------------------------------------
# Archive and Logging
# ---------------------------------------------------------------------------
# Path to the archive log markdown file
# PAC_ARCHIVE_LOG=path/to/archive_log.md

# ---------------------------------------------------------------------------
# Auto-commit
# ---------------------------------------------------------------------------
# Path to auto-commit config JSON
# PAC_AUTO_COMMIT_CONFIG=path/to/auto_commit_config.json
